local function startCooldownBar()
	cooldownGui.Visible = true
	cooldownFill.Size = UDim2.new(1, 0, 1, 0)

	local tween = TweenService:Create(
		cooldownFill,
		TweenInfo.new(cooldown, Enum.EasingStyle.Linear),
		{ Size = UDim2.new(1, 0, 0, 0) }
	)

	tween:Play()
	tween.Completed:Wait()
	cooldownGui.Visible = false
end

-- ====== TÌM TARGET ======
local function findClosestModelWithRootPart()
	if not currentRootPart then return nil end

	local closestModel
	local smallestDistance = 20

	for _, descendant in pairs(workspace:GetDescendants()) do
		if descendant:IsA("Model")
			and descendant:FindFirstChild("HumanoidRootPart")
			and descendant ~= currentCharacter then

			local ok, distance = pcall(function()
				return (currentRootPart.Position - descendant.HumanoidRootPart.Position).Magnitude
			end)

			if ok and distance and distance < smallestDistance then
				closestModel = descendant
				smallestDistance = distance
			end
		end
	end

	return closestModel
end

-- ====== DASH ======
local function sendDash()
	if not character or not communicate then return end

	local payload = {{
		Dash = Enum.KeyCode.W,
		Key = Enum.KeyCode.Q,
		Goal = "KeyPress"
	}}

	pcall(function()
		communicate:FireServer(unpack(payload))
	end)
end

-- ====== QUAY CAMERA ======
local function rotateCamera165()
	if not rootPart then return end
	local lookVector = rootPart.CFrame.LookVector
	camera.CFrame = CFrame.new(camera.CFrame.Position, camera.CFrame.Position - lookVector)
end

-- ====== ANIM ======
local ATTACK_ANIMS = {
	"10503381238",
	"13379003796"
}

local function isAttackAnimation(animId)
	for _, id in pairs(ATTACK_ANIMS) do
		if string.find(animId, id, 1, true) then
			return true
		end
	end
	return false
end

-- ====== BẮT ĐÁNH ======
local function onAnimationPlayed(track)
	if not toggleEnabled then return end
	if not track or not track.Animation then return end

	local animId = tostring(track.Animation.AnimationId)
	if isAttackAnimation(animId) then
		if tick() - lastDashTime < cooldown then return end

		local target = findClosestModelWithRootPart()
		if target then
			lastDashTime = tick()
			task.spawn(startCooldownBar)

			task.delay(0.26, function()
				sendDash()
				task.delay(0.2, rotateCamera165)
			end)
		end
	end
end

-- ====== CHARACTER ======
local function onCharacterAdded(char)
	character = char
	currentCharacter = char
	humanoid = char:WaitForChild("Humanoid")
	rootPart = char:WaitForChild("HumanoidRootPart")
	currentRootPart = rootPart
	communicate = char:FindFirstChild("Communicate")

	humanoid.AnimationPlayed:Connect(onAnimationPlayed)

	local animator = humanoid:FindFirstChildOfClass("Animator")
	if animator then
		animator.AnimationPlayed:Connect(onAnimationPlayed)
	end
end

LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
if LocalPlayer.Character then
	onCharacterAdded(LocalPlayer.Character)
end

-- ====== KÉO MENU ======
local dragging, dragInput, dragStart, startPos

toggleButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = toggleButton.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

toggleButton.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement
	or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		toggleButton.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

